---
layout: 'layouts/default.njk'
---

{%- from 'components/heading.njk' import heading %}
{%- from 'components/btn.njk' import btn %}

{%- call heading(tag='h1',sub=site.meta.lead,img='/_assets/img/encyclopedias/en-info.png') %}
{{ site.meta.title }}
{%- endcall %}

<div class="not-prose md:(grid-(& cols-2) gap-6)">

  <div class="game-info col-span-2">
    <a href="https://www.play-asia.com/search/legend+of+mana+remastered?tagid=145091" class="mb-8 w-full h-48 bg-(cover center) block rounded hover:(motion-safe:animate-waggle)" style="background-image: url('{{ '/' | url }}_assets/img/lom-hd.jpg');"><b class="sr-only">Buy HD Remaster</b></a>
    <ul class="ml-0 grid-(& cols-2) gap-6 md:grid-cols-4">
      <li>
        {{ btn({
          sub: 'Buy On',
          url: 'https://www.play-asia.com/legend-of-mana-remastered-english/13/70ecbf?tagid=145091',
          ico: 'mdi:nintendo-switch'
        }) }}
      </li>
      <li>
        {{ btn({
          sub: 'Buy On',
          url: 'https://www.play-asia.com/legend-of-mana-remastered-english/13/70ecb9?tagid=145091',
          ico: 'mdi:sony-playstation'
        }) }}
      </li>
      <li>
        {{ btn({
          sub: 'Buy On',
          url: 'https://xbox.com/en-US/games/store/legend-of-mana/9P2S2QVRB97N',
          ico: 'mdi:microsoft-xbox'
        }) }}
      </li>
      <li>
        {{ btn({
          sub: 'Buy On',
          url: 'https://store.steampowered.com/app/1175830/Legend_of_Mana/',
          ico: 'mdi:steam'
        }) }}
      </li>
    </ul>
  </div>
  <div class="pt-5 col-span-2">
    <h2 class="heading">Original Version</h2>
  </div>
  <div class="game-info group pb-8 relative md:(p-0)">
    <div>
      <img src="{{ '/' | url }}_assets/img/game.png" alt="Legend of Mana game art" class="mx-auto group-hover:(motion-safe:animate-waggle)" />
      <div class="pt-2 pb-5 text-sm">Legend of Mana is an RPG developed and published by Square in 1999 for the Sony Playstation (also on PSN).</div>
    </div>
    <p>
      {{ btn({
          slot: 'Original Game',
          sub: 'Buy',
          url: 'https://amazon.com/dp/B00004SWM0?tag=qrayg-20',
          ico: 'mdi:disc',
          block: true
        }) }}
    </p>
  </div>
  <div class="game-info group pb-8 relative md:(p-0)">
    <div>
      <img src="{{ '/' | url }}_assets/img/ost.png" alt="Legend of Mana OST art" class="mx-auto group-hover:(motion-safe:animate-waggle)" />
      <div class="pt-2 pb-5 text-sm">Legend of Mana OST was composed by Yoko Shimomura and contains some extremely beautify compositions.</div>
    </div>
    <p>
      {{ btn({
        slot: 'Original Game',
        sub: 'Buy',
        url: 'https://www.play-asia.com/seiken-densetsu-the-legend-of-mana-original-soundtrack/13/70bty?tagid=145091',
        ico: 'mdi:music',
        block: true
      }) }}
    </p>
  </div>

</div>
